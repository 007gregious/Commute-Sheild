ADDR=:8080
# Point DATABASE_URL at PgBouncer (commonly port 6432), not a direct database listener.
DATABASE_URL=postgres://postgres:postgres@localhost:6432/postgres?sslmode=disable&pool_max_conns=20&statement_cache_mode=describe
REDIS_URL=redis://localhost:6379/0
PGPOOL_MIN_CONNS=2
PGPOOL_MAX_CONNS=20
OTEL_EXPORTER_OTLP_ENDPOINT=

# Smile ID / identity onboarding
SMILE_ID_BASE_URL=https://api.smileidentity.com
SMILE_ID_PARTNER_ID=
SMILE_ID_API_KEY=
SMILE_ID_CALLBACK_URL=
SMILE_ID_JOB_TYPE=biometric_kyc
ERASURE_SIGNING_SECRET=
